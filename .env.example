# FUKU Coffee — environment variables
# Copy this to `.env` and fill in real values BEFORE going live.
# (.env is in .gitignore so secrets never get committed.)

# ---- Server ----
PORT=8765

# ---- Porter Logistics API ----
# Leave blank for MOCK mode (default). Add your real key to enable live bookings.
PORTER_API_KEY=
PORTER_BASE_URL=https://pfe-apigw.porter.in
# PORTER_BASE_URL=https://pfe-apigw-uat.porter.in   # sandbox
PORTER_MOCK=

# ---- Optional: override admin passwords from the env instead of editing server.py ----
# (server.py reads these if present; otherwise falls back to the USERS dict defaults)
# FUKU_PASS_AAKASH=
# FUKU_PASS_VIHANG=
# FUKU_PASS_NISARG=
# FUKU_PASS_CHILMAN=
# FUKU_PASS_SULAY=
